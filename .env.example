# ─── Vercel Postgres ───
# Go to: Vercel Dashboard → Storage → Postgres → .env.local tab → copy all
POSTGRES_URL=postgres://default:xxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require
POSTGRES_PRISMA_URL=postgres://default:xxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require&pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://default:xxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require
POSTGRES_URL_NO_SSL=postgres://default:xxxx@ep-xxx.us-east-1.aws.neon.tech/verceldb
POSTGRES_USER=default
POSTGRES_HOST=ep-xxx.us-east-1.aws.neon.tech
POSTGRES_PASSWORD=xxxx
POSTGRES_DATABASE=verceldb

# ─── Payload CMS ───
PAYLOAD_SECRET=generate-a-random-string-at-least-32-characters-long
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Vercel Blob (media uploads) ───
# Go to: Vercel Dashboard → Storage → Blob → Tokens tab → copy token
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxx

# ─── Optional: Cloudflare R2 (alternative to Vercel Blob) ───
# S3_ACCESS_KEY_ID=your-r2-access-key
# S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_BUCKET=jj-events-media
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_REGION=auto

# ─── Optional: Analytics & Email ───
# RESEND_API_KEY=your-resend-api-key
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
